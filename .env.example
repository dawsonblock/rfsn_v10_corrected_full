# RFSN v10 — environment variable template
# Copy to .env and fill in values before running docker-compose.
#
# NEVER commit .env to version control.

# Required: ClickHouse password (no default — empty string is not accepted in production)
CLICKHOUSE_PASSWORD=change_me_before_production

# Required if telemetry is enabled: HMAC key for prompt sanitisation
RFSN_TELEMETRY_HMAC_KEY=change_me_before_production

# Optional overrides
RFSN_LOG_LEVEL=INFO
RFSN_BACKEND=numpy
